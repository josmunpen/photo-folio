---
type VariantMap = Record<string, Record<string, string>>;

interface Props {
  photo: {
    title: string;
    alt?: string;
    src?: string;
    variants?: VariantMap;
  };
  class?: string;
  sizes?: string;
  maxWidth?: number;
}

const {
  photo,
  class: className = "",
  sizes = "(min-width: 900px) 80vw, 100vw",
  maxWidth = 2400,
} = Astro.props;

function entriesFor(format: string) {
  const variants = photo.variants?.[format];
  if (!variants) return [];

  return Object.entries(variants)
    .filter(([width]) => Number(width) <= maxWidth)
    .sort(([a], [b]) => Number(a) - Number(b));
}

function srcset(format: string) {
  const entries = entriesFor(format);
  if (!entries.length) return undefined;

  return entries.map(([width, url]) => `${url} ${width}w`).join(", ");
}

function largestVariant(formats: string[]) {
  for (const format of formats) {
    const entries = entriesFor(format);
    const largest = entries.at(-1);
    if (largest) return largest[1];
  }

  return "";
}

const avifSrcset = srcset("avif");
const webpSrcset = srcset("webp");
const jpegSrcset = srcset("jpeg") || srcset("jpg");
const fallbackSrc = largestVariant(["webp", "avif", "jpeg", "jpg"]) || photo.src || "";
const alt = photo.alt || photo.title;
---

<picture>
  {avifSrcset && <source type="image/avif" srcset={avifSrcset} sizes={sizes} />}
  {webpSrcset && <source type="image/webp" srcset={webpSrcset} sizes={sizes} />}
  {jpegSrcset && <source type="image/jpeg" srcset={jpegSrcset} sizes={sizes} />}
  <img class={className} src={fallbackSrc} alt={alt} loading="lazy" decoding="async" />
</picture>
