---
import PhotoGrid from "../components/PhotoGrid.astro";
import photos from "../data/photos.json";

const pageTitle = "josmunpen";
const pageDescription = "fotografías y desvaríos";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main class="site">
      <header class="hero">
        <h1>{pageTitle}</h1>
        <p class="intro">{pageDescription}</p>
      </header>

      <PhotoGrid photos={photos} />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color: #171717;
    background: #fbfaf7;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-synthesis: none;
    text-rendering: optimizeLegibility;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #fbfaf7;
  }

  body.no-scroll {
    overflow: hidden;
  }

  button {
    font: inherit;
  }

  .site {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 56px 0 80px;
  }

  .hero {
    max-width: 720px;
    margin-bottom: 56px;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: #76716a;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3.2rem, 10vw, 8rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.07em;
  }

  .intro {
    max-width: 560px;
    margin: 28px 0 0;
    color: #5f5b55;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.7;
  }

  .photo-list {
    display: grid;
    gap: 72px;
  }

  .photo-item {
    display: grid;
    gap: 16px;
  }

  .photo-item:nth-child(even) {
    width: min(860px, 100%);
    margin-left: auto;
  }

  .photo-button {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: zoom-in;
  }

  .photo-image {
    display: block;
    width: 100%;
    height: auto;
    background: #ebe7df;
    box-shadow: 0 24px 60px rgb(0 0 0 / 8%);
  }

  .caption {
    max-width: 560px;
  }

  .caption h2 {
    margin: 0 0 6px;
    font-size: 1rem;
    font-weight: 600;
  }

  .caption p {
    margin: 0;
    color: #6c675f;
    line-height: 1.6;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 10;
    display: grid;
    grid-template-rows: 1fr auto;
    place-items: center;
    gap: 20px;
    padding: 32px;
    background: rgb(251 250 247 / 96%);
  }

  .lightbox-image {
    max-width: min(1200px, 100%);
    max-height: 78vh;
    object-fit: contain;
    box-shadow: 0 24px 80px rgb(0 0 0 / 18%);
  }

  .lightbox-caption {
    width: min(720px, 100%);
    text-align: center;
  }

  .lightbox-caption h2 {
    margin: 0 0 6px;
    font-size: 1rem;
  }

  .lightbox-caption p {
    margin: 0;
    color: #6c675f;
  }

  .lightbox-close {
    position: fixed;
    top: 18px;
    right: 22px;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 999px;
    background: #171717;
    color: white;
    cursor: pointer;
    font-size: 1.8rem;
    line-height: 1;
  }

  @media (max-width: 700px) {
    .site {
      width: min(100% - 24px, 1120px);
      padding-top: 36px;
    }

    .photo-list {
      gap: 48px;
    }

    .lightbox {
      padding: 16px;
    }
  }
</style>
