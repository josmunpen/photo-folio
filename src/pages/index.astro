---
import PhotoGrid from "../components/PhotoGrid.astro";
import photos from "../data/photos.json";

const pageTitle = "josmunpen";
const pageDescription = "fotografías y desvaríos";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main class="site">
      <header class="hero">
        <h1>{pageTitle}</h1>
        <p class="intro">{pageDescription}</p>
      </header>

      <PhotoGrid photos={photos} />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --lightbox-gap: 14px;
    --lightbox-padding: 20px;
    --lightbox-picture-max-width: min(96vw, 2200px);
    --lightbox-picture-max-height: 88vh;
    --lightbox-image-max-height: 88vh;

    color: #171717;
    background: #fbfaf7;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-synthesis: none;
    text-rendering: optimizeLegibility;
  }

  :root[data-lightbox-size="balanced"] {
    --lightbox-padding: 28px;
    --lightbox-picture-max-width: min(90vw, 1600px);
    --lightbox-picture-max-height: 84vh;
    --lightbox-image-max-height: 84vh;
  }

  :root[data-lightbox-size="immersive"] {
    --lightbox-gap: 14px;
    --lightbox-padding: 20px;
    --lightbox-picture-max-width: min(96vw, 2200px);
    --lightbox-picture-max-height: 88vh;
    --lightbox-image-max-height: 88vh;
  }

  :root[data-lightbox-size="fullscreen"] {
    --lightbox-gap: 0;
    --lightbox-padding: 0;
    --lightbox-picture-max-width: 100vw;
    --lightbox-picture-max-height: 100vh;
    --lightbox-image-max-height: 100vh;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #fbfaf7;
  }

  body.no-scroll {
    overflow: hidden;
  }

  button {
    font: inherit;
  }

  .site {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 56px 0 80px;
  }

  .hero {
    max-width: 720px;
    margin-bottom: 56px;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: #76716a;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3.2rem, 10vw, 8rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.07em;
  }

  .intro {
    max-width: 560px;
    margin: 28px 0 0;
    color: #5f5b55;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.7;
  }

  .photo-list {
    display: grid;
    gap: 72px;
  }

  .photo-item {
    display: grid;
    gap: 16px;
  }

  .photo-item:nth-child(even) {
    width: min(860px, 100%);
    margin-left: auto;
  }

  .photo-button {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: zoom-in;
  }

  .photo-image {
    display: block;
    width: 100%;
    height: auto;
    background: #ebe7df;
    box-shadow: 0 24px 60px rgb(0 0 0 / 8%);
  }

  .caption {
    max-width: 560px;
  }

  .caption h2 {
    margin: 0 0 6px;
    font-size: 1rem;
    font-weight: 600;
  }

  .caption p {
    margin: 0;
    color: #6c675f;
    line-height: 1.6;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 10;
    display: grid;
    grid-template-rows: 1fr auto;
    place-items: center;
    gap: var(--lightbox-gap);
    padding: var(--lightbox-padding);
    background: rgb(251 250 247 / 96%);
  }

  .lightbox-picture {
    display: grid;
    place-items: center;
    max-width: var(--lightbox-picture-max-width);
    max-height: var(--lightbox-picture-max-height);
  }

  .lightbox-image {
    display: block;
    max-width: 100%;
    max-height: var(--lightbox-image-max-height);
    object-fit: contain;
    box-shadow: 0 24px 80px rgb(0 0 0 / 18%);
  }

  :root[data-zoom-mode="basic"] .lightbox-picture,
  :root[data-zoom-mode="basic"] .lightbox-image {
    cursor: zoom-in;
  }

  :root[data-zoom-mode="pro"] .lightbox-picture,
  :root[data-zoom-mode="pro"] .lightbox-image {
    cursor: zoom-in;
  }

  :root[data-zoom-mode="pro"] .lightbox.is-pro-lens-active .lightbox-picture,
  :root[data-zoom-mode="pro"] .lightbox.is-pro-lens-active .lightbox-image {
    cursor: none;
  }

  :root[data-zoom-mode="none"] .lightbox-picture,
  :root[data-zoom-mode="none"] .lightbox-image {
    cursor: default;
  }

  .lightbox.is-zoomed {
    display: block;
    overflow: auto;
    padding: 56px;
  }

  .lightbox.is-zoomed .lightbox-picture {
    display: block;
    width: max-content;
    max-width: none;
    max-height: none;
    margin: 0 auto;
    cursor: zoom-out;
  }

  .lightbox.is-zoomed .lightbox-image {
    width: auto;
    max-width: none;
    max-height: none;
    cursor: zoom-out;
  }

  .lightbox.is-zoomed .lightbox-caption {
    display: none;
  }

  .lightbox-lens {
    position: fixed;
    z-index: 11;
    border: 2px solid rgb(255 255 255 / 92%);
    border-radius: 999px;
    background-repeat: no-repeat;
    box-shadow:
      0 16px 48px rgb(0 0 0 / 28%),
      inset 0 0 0 1px rgb(0 0 0 / 18%);
    pointer-events: none;
  }

  .lightbox-lens[hidden] {
    display: none;
  }

  @media (pointer: coarse) {
    .lightbox-lens {
      display: none;
    }
  }

  .lightbox-caption {
    width: min(720px, 100%);
    text-align: center;
  }

  .lightbox-caption h2 {
    margin: 0 0 6px;
    font-size: 1rem;
  }

  .lightbox-caption p {
    margin: 0;
    color: #6c675f;
  }

  :root[data-lightbox-size="fullscreen"] .lightbox {
    grid-template-rows: 1fr;
  }

  :root[data-lightbox-size="fullscreen"] .lightbox-caption {
    position: fixed;
    bottom: 18px;
    left: 50%;
    width: min(720px, calc(100% - 32px));
    padding: 12px 16px;
    border-radius: 999px;
    background: rgb(251 250 247 / 82%);
    transform: translateX(-50%);
    backdrop-filter: blur(10px);
  }

  .lightbox-close {
    position: fixed;
    top: 18px;
    right: 22px;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 999px;
    background: #171717;
    color: white;
    cursor: pointer;
    font-size: 1.8rem;
    line-height: 1;
  }

  @media (max-width: 700px) {
    .site {
      width: min(100% - 24px, 1120px);
      padding-top: 36px;
    }

    .photo-list {
      gap: 48px;
    }

    .lightbox {
      padding: min(var(--lightbox-padding), 16px);
    }

    :root[data-lightbox-size="balanced"],
    :root[data-lightbox-size="immersive"] {
      --lightbox-picture-max-width: calc(100vw - 32px);
      --lightbox-picture-max-height: 82vh;
      --lightbox-image-max-height: 82vh;
    }

    .lightbox.is-zoomed {
      padding: 24px;
    }
  }
</style>
